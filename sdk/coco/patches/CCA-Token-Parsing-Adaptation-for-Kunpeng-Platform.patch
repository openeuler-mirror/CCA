@@ -43,7 +44,7 @@ pub struct Realm {
     pub rim: Vec<u8>,         // 44238 => bytes .size {32,48,64}
     pub rem: [Vec<u8>; 4],    // 44239 => [ 4*4 bytes .size {32,48,64} ]
