-    pub raw_rak: [u8; 97],    // 44237 => bytes .size 97 (profile=="")
+    pub raw_rak: [u8; 133],   // 44237 => bytes .size 133 (P-521: 1 + 66 + 66)
     pub cose_rak: Vec<u8>,    // 44237 => bytes .cbor COSE_Key (profile==REALM_PROFILE)
     pub rak_hash_alg: String, // 44240 => text
 
@@ -65,7 +66,7 @@ impl Realm {
             rim: vec![0, 64],
             rem: Default::default(),
             hash_alg: String::from(""),
-            raw_rak: [0; 97],
+            raw_rak: [0; 133],
             cose_rak: Default::default(),
             rak_hash_alg: String::from(""),
             claims_set: ClaimsSet::none(),
@@ -141,11 +142,11 @@ impl Realm {
         }
 
         // RAK format depends on the token profile
-        if self.profile == REALM_PROFILE {
+        if self.profile == REALM_PROFILE || self.profile == REALM_PROFILE_HUAWEI {
             if self.cose_rak.is_empty() {
                 return Err(Error::Sema("RAK COSE_Key not set".to_string()));
             }
-        } else if self.raw_rak == [0; 97] {
+        } else if self.raw_rak == [0; 133] {
             return Err(Error::Sema("RAK raw public key not set".to_string()));
         }
 
@@ -161,7 +162,7 @@ impl Realm {
 
         let p = to_tstr(v, "profile")?;
 
-        if p != REALM_PROFILE {
+        if p != REALM_PROFILE && p != REALM_PROFILE_HUAWEI {
             return Err(Error::UnknownProfile(p.to_string()));
         }
 
@@ -259,6 +260,11 @@ impl Realm {
                 )));
             }
             self.raw_rak[..].clone_from_slice(&x);
+        } else if self.profile == REALM_PROFILE_HUAWEI {
+            self.cose_rak = x.clone();
+            if let Err(e) = Self::extract_raw_rak_from_cose(&x, &mut self.raw_rak) {
+                eprintln!("WARN: failed to extract raw RAK from COSE_Key: {:?}", e);
+            }
         } else {
             self.cose_rak = x
         }
@@ -268,6 +274,40 @@ impl Realm {
         Ok(())
     }
 
+    fn extract_raw_rak_from_cose(cose_key: &[u8], raw_rak: &mut [u8; 133]) -> Result<(), Error> {
+        let v: Value = from_reader(cose_key).map_err(|e| Error::Syntax(e.to_string()))?;
+        let map = match v {
+            Value::Map(m) => m,
+            _ => return Err(Error::TypeMismatch("expecting COSE_Key map".to_string())),
+        };
+
+        let mut x_bytes: Option<Vec<u8>> = None;
+        let mut y_bytes: Option<Vec<u8>> = None;
+
+        for (k, v) in map {
+            if let Value::Integer(i) = k {
+                match i.into() {
+                    -2 => { x_bytes = v.as_bytes().map(|b| b.to_vec()); }
+                    -3 => { y_bytes = v.as_bytes().map(|b| b.to_vec()); }
+                    _ => {}
+                }
+            }
+        }
+
+        let x = x_bytes.ok_or_else(|| Error::MissingClaim("x coordinate".to_string()))?;
+        let y = y_bytes.ok_or_else(|| Error::MissingClaim("y coordinate".to_string()))?;
+
+        if x.len() != 66 || y.len() != 66 {
+            return Err(Error::Sema(format!("invalid EC coordinate lengths: x={}, y={}", x.len(), y.len())));
+        }
+
+        raw_rak[0] = 0x04;
+        raw_rak[1..67].copy_from_slice(&x);
+        raw_rak[67..133].copy_from_slice(&y);
+
+        Ok(())
+    }
+
     fn set_rem(&mut self, v: &Value) -> Result<(), Error> {
         if self.claims_set.contains(Claims::Rem) {
             return Err(Error::DuplicatedClaim(
@@ -330,7 +370,7 @@ impl Realm {
     }
 
     pub fn get_realm_key(&self) -> Result<Vec<u8>, Error> {
-        let rak = if self.profile == REALM_PROFILE {
+        let rak = if self.profile == REALM_PROFILE || self.profile == REALM_PROFILE_HUAWEI {
             self.cose_rak.clone()
         } else {
             self.raw_rak.clone().to_vec()
@@ -343,6 +383,14 @@ impl Realm {
         Ok(rak)
     }
 
+    pub fn get_raw_realm_key(&self) -> Result<Vec<u8>, Error> {
+        let rak = self.raw_rak.clone().to_vec();
+        if rak == [0u8; 133].to_vec() {
+            return Err(Error::MissingClaim("No raw realm Key".to_string()));
+        }
+        Ok(rak)
+    }
+
     pub fn get_rak_hash_alg(&self) -> Result<String, Error> {
         let rak_hash_alg = self.rak_hash_alg.clone();
 
