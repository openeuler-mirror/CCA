From c346c2be62a8cd27979d29b32d9bd98d1b33208b Mon Sep 17 00:00:00 2001
From: yxk <yangxiangkai@huawei.com>
Date: Tue, 13 Jan 2026 00:42:46 +0800
Subject: [PATCH 7/8] drivers/hinic3: CCA supports hinic3 SR-IOV.

---
 .../net/ethernet/huawei/hinic3/cqm/cqm_db.c   | 44 ++++++++++++++++++-
 .../ethernet/huawei/hinic3/hinic3_nic_io.h    |  8 ++++
 .../ethernet/huawei/hinic3/hw/hinic3_cmdq.c   |  9 ++++
 .../ethernet/huawei/hinic3/hw/hinic3_hwif.c   | 23 ++++++++++
 .../ethernet/huawei/hinic3/hw/hinic3_lld.c    | 11 +++++
 .../ethernet/huawei/hinic3/hw/hinic3_mbox.c   | 15 +++++++
 6 files changed, 108 insertions(+), 2 deletions(-)

diff --git a/drivers/net/ethernet/huawei/hinic3/cqm/cqm_db.c b/drivers/net/ethernet/huawei/hinic3/cqm/cqm_db.c
index 2a24e4a98beb..d43873e6c991 100644
--- a/drivers/net/ethernet/huawei/hinic3/cqm/cqm_db.c
+++ b/drivers/net/ethernet/huawei/hinic3/cqm/cqm_db.c
@@ -19,6 +19,9 @@
 #include "cqm_object_intern.h"
 #include "cqm_main.h"
 #include "cqm_db.h"
+#ifdef CONFIG_HISI_CCADA_HOST
+#include <asm/hisi_cca_da.h>
+#endif
 
 /**
  * cqm_db_addr_alloc - Apply for a page of hardware doorbell and dwqe.
@@ -244,7 +247,12 @@ s32 cqm_ring_hardware_db(void *ex_handle, u32 service_type, u8 db_count, u64 db)
 	 * the parameter is not checked.
 	 */
 	wmb();
+#ifdef CONFIG_HISI_CCADA_HOST
+	rme_writeq_hook(db, (u64 *)service->hardware_db_vaddr + db_count,
+		    (struct pci_dev *)handle->pcidev_hdl);
+#else
 	*((u64 *)service->hardware_db_vaddr + db_count) = db;
+#endif
 	return CQM_SUCCESS;
 }
 EXPORT_SYMBOL(cqm_ring_hardware_db);
@@ -276,7 +284,11 @@ s32 cqm_ring_hardware_db_fc(void *ex_handle, u32 service_type, u8 db_count,
 	wmb();
 	dbaddr = (u8 *)service->hardware_db_vaddr +
 		 ((pagenum + HIFC_DB_FAKE_VF_OFFSET) * HINIC3_DB_PAGE_SIZE);
+#ifdef CONFIG_HISI_CCADA_HOST
+	rme_writeq_hook(db, (u64 *)dbaddr + db_count, (struct pci_dev *)handle->pcidev_hdl);
+#else
 	*((u64 *)dbaddr + db_count) = db;
+#endif
 	return CQM_SUCCESS;
 }
 
@@ -315,8 +327,14 @@ s32 cqm_ring_direct_wqe_db(void *ex_handle, u32 service_type, u8 db_count,
 	 * the parameter is not checked.
 	 */
 	wmb();
-	for (i = 0; i < 0x80 / 0x8; i++)
+	for (i = 0; i < 0x80 / 0x8; i++) {
+#ifdef CONFIG_HISI_CCADA_HOST
+		rme_writeq_hook(*tmp++, (u64 *)service->dwqe_vaddr + 0x40 + i,
+			    (struct pci_dev *)handle->pcidev_hdl);
+#else
 		*((u64 *)service->dwqe_vaddr + 0x40 + i) = *tmp++;
+#endif
+	}
 
 	return CQM_SUCCESS;
 }
@@ -339,17 +357,34 @@ s32 cqm_ring_direct_wqe_db_fc(void *ex_handle, u32 service_type,
 	 * the parameter is not checked.
 	 */
 	wmb();
+#ifdef CONFIG_HISI_CCADA_HOST
+	rme_writeq_hook(tmp[0x2], (u64 *)service->dwqe_vaddr + 0x0,
+		    (struct pci_dev *)handle->pcidev_hdl);
+	rme_writeq_hook(tmp[0x3], (u64 *)service->dwqe_vaddr + 0x1,
+		    (struct pci_dev *)handle->pcidev_hdl);
+	rme_writeq_hook(tmp[0x0], (u64 *)service->dwqe_vaddr + 0x2,
+		    (struct pci_dev *)handle->pcidev_hdl);
+	rme_writeq_hook(tmp[0x1], (u64 *)service->dwqe_vaddr + 0x3,
+		    (struct pci_dev *)handle->pcidev_hdl);
+#else
 	*((u64 *)service->dwqe_vaddr + 0x0) = tmp[0x2];
 	*((u64 *)service->dwqe_vaddr + 0x1) = tmp[0x3];
 	*((u64 *)service->dwqe_vaddr + 0x2) = tmp[0x0];
 	*((u64 *)service->dwqe_vaddr + 0x3) = tmp[0x1];
+#endif
 	tmp += 0x4;
 
 	/* The FC use 256B WQE. The directwqe is written at block0,
 	 * and the length is 256B
 	 */
-	for (i = 0x4; i < 0x20; i++)
+	for (i = 0x4; i < 0x20; i++) {
+#ifdef CONFIG_HISI_CCADA_HOST
+		rme_writeq_hook(*tmp++, (u64 *)service->dwqe_vaddr + i,
+			    (struct pci_dev *)handle->pcidev_hdl);
+#else
 		*((u64 *)service->dwqe_vaddr + i) = *tmp++;
+#endif
+	}
 
 	return CQM_SUCCESS;
 }
@@ -387,7 +422,12 @@ s32 cqm_ring_hardware_db_update_pri(void *ex_handle, u32 service_type,
 	 * the parameter is not checked.
 	 */
 	wmb();
+#ifdef CONFIG_HISI_CCADA_HOST
+	rme_writeq_hook(db, (u64 *)service->hardware_db_vaddr + db_count,
+		    (struct pci_dev *)handle->pcidev_hdl);
+#else
 	*((u64 *)service->hardware_db_vaddr + db_count) = db;
+#endif
 
 	return CQM_SUCCESS;
 }
diff --git a/drivers/net/ethernet/huawei/hinic3/hinic3_nic_io.h b/drivers/net/ethernet/huawei/hinic3/hinic3_nic_io.h
index c5e02adae49b..2e96413ec07f 100644
--- a/drivers/net/ethernet/huawei/hinic3/hinic3_nic_io.h
+++ b/drivers/net/ethernet/huawei/hinic3/hinic3_nic_io.h
@@ -7,6 +7,9 @@
 #include "hinic3_crm.h"
 #include "hinic3_common.h"
 #include "hinic3_wq.h"
+#ifdef CONFIG_HISI_CCADA_HOST
+#include <asm/hisi_cca_da.h>
+#endif
 
 #define HINIC3_MAX_TX_QUEUE_DEPTH	65536
 #define HINIC3_MAX_RX_QUEUE_DEPTH	16384
@@ -317,7 +320,12 @@ static inline void hinic3_write_db(struct hinic3_io_queue *queue, int cos,
 
 	wmb(); /* Write all before the doorbell */
 
+#ifdef CONFIG_HISI_CCADA_HOST
+	rme_writeq_hook(*((u64 *)(u8 *)&db), DB_ADDR(queue, pi),
+		    to_pci_dev((struct device *)queue->wq.dev_hdl));
+#else
 	writeq(*((u64 *)(u8 *)&db), DB_ADDR(queue, pi));
+#endif
 }
 
 struct hinic3_dyna_qp_params {
diff --git a/drivers/net/ethernet/huawei/hinic3/hw/hinic3_cmdq.c b/drivers/net/ethernet/huawei/hinic3/hw/hinic3_cmdq.c
index 9f10131779f5..ac09bf7bc356 100644
--- a/drivers/net/ethernet/huawei/hinic3/hw/hinic3_cmdq.c
+++ b/drivers/net/ethernet/huawei/hinic3/hw/hinic3_cmdq.c
@@ -27,6 +27,9 @@
 #include "hinic3_hwif.h"
 #include "npu_cmdq_base_defs.h"
 #include "hinic3_cmdq.h"
+#ifdef CONFIG_HISI_CCADA_HOST
+#include <asm/hisi_cca_da.h>
+#endif
 
 #define CMDQ_CMD_TIMEOUT				5000 /* millisecond */
 #define CMDQ_CMD_RETRY_TIMEOUT				1000U
@@ -336,7 +339,13 @@ static void cmdq_set_db(struct hinic3_cmdq *cmdq,
 	db.db_head = hinic3_hw_be32(db.db_head);
 
 	wmb();    /* write all before the doorbell */
+#ifdef CONFIG_HISI_CCADA_HOST
+	rme_writeq_hook(*((u64 *)&db), CMDQ_DB_ADDR(db_base, prod_idx),
+		    (struct pci_dev *)cmdq->hwdev->pcidev_hdl);
+#else
 	writeq(*((u64 *)&db), CMDQ_DB_ADDR(db_base, prod_idx));
+#endif
+
 }
 
 static void cmdq_wqe_fill(void *dst, const void *src, int wqe_size)
diff --git a/drivers/net/ethernet/huawei/hinic3/hw/hinic3_hwif.c b/drivers/net/ethernet/huawei/hinic3/hw/hinic3_hwif.c
index 8590f70e1387..9ddedd727234 100644
--- a/drivers/net/ethernet/huawei/hinic3/hw/hinic3_hwif.c
+++ b/drivers/net/ethernet/huawei/hinic3/hw/hinic3_hwif.c
@@ -15,6 +15,9 @@
 #include "hinic3_common.h"
 #include "hinic3_hwdev.h"
 #include "hinic3_hwif.h"
+#ifdef CONFIG_HISI_CCADA_HOST
+#include <asm/hisi_cca_da.h>
+#endif
 
 #ifndef CONFIG_MODULE_PROF
 #define WAIT_HWIF_READY_TIMEOUT				10000
@@ -168,22 +171,42 @@
 
 u32 hinic3_hwif_read_reg(struct hinic3_hwif *hwif, u32 reg)
 {
+#ifdef CONFIG_HISI_CCADA_HOST
+	if (HINIC3_GET_REG_FLAG(reg) == HINIC3_MGMT_REGS_FLAG)
+		return be32_to_cpu(rme_readl_hook(hwif->mgmt_regs_base +
+					 HINIC3_GET_REG_ADDR(reg), (struct pci_dev *)hwif->pdev));
+	else
+		return be32_to_cpu(rme_readl_hook(hwif->cfg_regs_base +
+					 HINIC3_GET_REG_ADDR(reg), (struct pci_dev *)hwif->pdev));
+#else
 	if (HINIC3_GET_REG_FLAG(reg) == HINIC3_MGMT_REGS_FLAG)
 		return be32_to_cpu(readl(hwif->mgmt_regs_base +
 					 HINIC3_GET_REG_ADDR(reg)));
 	else
 		return be32_to_cpu(readl(hwif->cfg_regs_base +
 					 HINIC3_GET_REG_ADDR(reg)));
+#endif
 }
 
 void hinic3_hwif_write_reg(struct hinic3_hwif *hwif, u32 reg, u32 val)
 {
+#ifdef CONFIG_HISI_CCADA_HOST
+	if (HINIC3_GET_REG_FLAG(reg) == HINIC3_MGMT_REGS_FLAG)
+		rme_writel_hook(cpu_to_be32(val),
+			    hwif->mgmt_regs_base + HINIC3_GET_REG_ADDR(reg),
+				(struct pci_dev *)hwif->pdev);
+	else
+		rme_writel_hook(cpu_to_be32(val),
+			    hwif->cfg_regs_base + HINIC3_GET_REG_ADDR(reg),
+				(struct pci_dev *)hwif->pdev);
+#else
 	if (HINIC3_GET_REG_FLAG(reg) == HINIC3_MGMT_REGS_FLAG)
 		writel(cpu_to_be32(val),
 		       hwif->mgmt_regs_base + HINIC3_GET_REG_ADDR(reg));
 	else
 		writel(cpu_to_be32(val),
 		       hwif->cfg_regs_base + HINIC3_GET_REG_ADDR(reg));
+#endif
 }
 
 bool get_card_present_state(struct hinic3_hwdev *hwdev)
diff --git a/drivers/net/ethernet/huawei/hinic3/hw/hinic3_lld.c b/drivers/net/ethernet/huawei/hinic3/hw/hinic3_lld.c
index b7f9db5453c3..3784b74121d2 100644
--- a/drivers/net/ethernet/huawei/hinic3/hw/hinic3_lld.c
+++ b/drivers/net/ethernet/huawei/hinic3/hw/hinic3_lld.c
@@ -37,6 +37,10 @@
 #include "hinic3_devlink.h"
 #include "vram_common.h"
 
+#ifdef CONFIG_HISI_CCADA_HOST
+#include <asm/hisi_cca_da.h>
+#endif
+
 enum partition_dev_type {
 	PARTITION_DEV_NONE = 0,
 	PARTITION_DEV_SHARED,
@@ -2431,6 +2435,10 @@ int hinic3_lld_init(void)
 	pr_info("%s - version %s\n", HINIC3_DRV_DESC, HINIC3_DRV_VERSION);
 	memset(g_uld_info, 0, sizeof(g_uld_info));
 
+#ifdef CONFIG_HISI_CCADA_HOST
+	hisi_pcipc_ns_add(hinic3_pci_table);
+#endif
+
 	hinic3_lld_lock_init();
 	hinic3_uld_lock_init();
 
@@ -2456,6 +2464,9 @@ int hinic3_lld_init(void)
 
 void hinic3_lld_exit(void)
 {
+#ifdef CONFIG_HISI_CCADA_HOST
+	hisi_pcipc_ns_remove(hinic3_pci_table);
+#endif
 	pci_unregister_driver(&hinic3_driver);
 
 	hinic3_module_post_exit();
diff --git a/drivers/net/ethernet/huawei/hinic3/hw/hinic3_mbox.c b/drivers/net/ethernet/huawei/hinic3/hw/hinic3_mbox.c
index 362626247eed..f1857078555d 100644
--- a/drivers/net/ethernet/huawei/hinic3/hw/hinic3_mbox.c
+++ b/drivers/net/ethernet/huawei/hinic3/hw/hinic3_mbox.c
@@ -19,6 +19,9 @@
 #include "hinic3_prof_adap.h"
 #include "hinic3_common.h"
 #include "hinic3_mbox.h"
+#ifdef CONFIG_HISI_CCADA_HOST
+#include <asm/hisi_cca_da.h>
+#endif
 
 #define HINIC3_MBOX_USEC_50	50
 
@@ -903,8 +906,14 @@ static void mbox_copy_header(struct hinic3_hwdev *hwdev,
 	u32 i, idx_max = MBOX_HEADER_SZ / sizeof(u32);
 
 	for (i = 0; i < idx_max; i++) {
+#ifdef CONFIG_HISI_CCADA_HOST
+		__rme_raw_writel_hook(cpu_to_be32(*(data + i)),
+				  mbox->data + i * sizeof(u32),
+			     (struct pci_dev *)hwdev->hwif->pdev);
+#else
 		__raw_writel(cpu_to_be32(*(data + i)),
 			     mbox->data + i * sizeof(u32));
+#endif
 	}
 }
 
@@ -926,8 +935,14 @@ static int mbox_copy_send_data(struct hinic3_hwdev *hwdev,
 	idx_max = ALIGN(data_len, chk_sz) / chk_sz;
 
 	for (i = 0; i < idx_max; i++) {
+#ifdef CONFIG_HISI_CCADA_HOST
+		__rme_raw_writel_hook(cpu_to_be32(*(data + i)),
+				  mbox->data + MBOX_HEADER_SZ + i * sizeof(u32),
+				  (struct pci_dev *)hwdev->hwif->pdev);
+#else
 		__raw_writel(cpu_to_be32(*(data + i)),
 			     mbox->data + MBOX_HEADER_SZ + i * sizeof(u32));
+#endif
 	}
 
 	return 0;
